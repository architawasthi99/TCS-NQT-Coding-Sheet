You are given an array of integers arr[]. You have to reverse the given array.

Soln:-
# include <bits/stdc++.h>
using namespace std;
void reversearray(vector<int>&arr){
    int left=0;
    int right=arr.size()-1;
    while(left<right){
        swap(arr[left],arr[right]);
        left++;
        right--;
    }
}
int main(){
    int n;
    cin>>n;
    vector<int>arr(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    reversearray(arr);
    for(int x:arr){
        cout<<x<<" ";
    }
    return 0;
}
