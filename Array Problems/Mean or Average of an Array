Given an array arr[], return the floor value of the mean of its elements.

Examples:
Input: arr[] = [1, 3, 4, 2, 6, 5, 8, 7]
Output: 4
Explanation: Sum of the elements is 1 + 3 + 4 + 2 + 6 + 5 + 8 + 7 = 36, Mean = 36/8 = 4.5, floor(4.5) = 4.

Soln:-
# include <bits/stdc++.h>
using namespace std;
int average(vector<int>&arr){
    int sum=0;
    for(int i=0;i<arr.size();i++){
        sum+=arr[i];
    }
    int avg=floor(1.0*sum/arr.size());
    return avg;
}
int main(){
    int n;
    cin>>n;
    vector<int>arr(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    cout<<average(arr);
    return 0;
}
